# FlowPilot Configuration
# Copy to .env and fill in your API keys

# LLM Provider (set ONE of these -- the system auto-detects)
OPENAI_API_KEY=sk-your-openai-key-here
# GEMINI_API_KEY=your-gemini-key-here

# If neither key is set, FlowPilot runs in MOCK mode with realistic demo data.
# Mock mode is fully functional for demos and evaluation.

# Server
HOST=0.0.0.0
PORT=8000
